<%- include('../partials/head', {title: 'Messages'}) %>
<body>
<div class="app-wrapper">
  <%- include('../partials/sidebar-student', {activePage: 'messages', user, unreadMessages: 0}) %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title">
        <h1>💬 Messages</h1>
      </div>
      <button onclick="toggleCompose()" class="btn btn-primary">✉️ Nouveau message</button>
    </div>
    <div class="page-content">
      <!-- Compose -->
      <div id="composeBox" style="display:none" class="card" style="margin-bottom:24px">
        <h3 style="margin-bottom:20px">✉️ Nouveau message</h3>
        <div class="form-group">
          <label class="form-label">Destinataire (formateur)</label>
          <select id="recipient" class="form-control">
            <option value="">-- Choisir un formateur --</option>
            <% trainers.forEach(t => { %>
            <option value="<%= t.id %>"><%= t.first_name %> (<%= t.username %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Objet</label>
          <input type="text" id="subject" class="form-control" placeholder="Ex: Question sur le cours Email">
        </div>
        <div class="form-group">
          <label class="form-label">Message</label>
          <textarea id="msgBody" class="form-control" rows="5" placeholder="Écrivez votre message..."></textarea>
        </div>
        <div style="display:flex;gap:12px">
          <button onclick="sendMessage()" class="btn btn-primary">📨 Envoyer</button>
          <button onclick="toggleCompose()" class="btn btn-outline">Annuler</button>
        </div>
      </div>

      <div class="grid-2">
        <div>
          <h3 style="margin-bottom:16px">📥 Messages reçus (<%= inbox.length %>)</h3>
          <% if (inbox.length === 0) { %>
          <div class="card" style="text-align:center;color:var(--muted);padding:40px">
            <div style="font-size:2.5rem">📭</div>
            <p>Aucun message reçu</p>
          </div>
          <% } else { %>
          <% inbox.forEach(m => { %>
          <div class="message-item <%= !m.is_read ? 'unread' : '' %>" onclick="showMsg(this)" data-body="<%= m.body.replace(/"/g, '&quot;') %>" data-subject="<%= m.subject %>" data-from="<%= m.sender_name %>">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px">
              <div class="avatar avatar-sm" style="background:<%= m.avatar_color || '#3B82F6' %>">
                <%= m.sender_name ? m.sender_name.charAt(0).toUpperCase() : 'F' %>
              </div>
              <div>
                <strong><%= m.sender_name %></strong>
                <% if (!m.is_read) { %><span class="notif-dot"></span><% } %>
              </div>
              <span style="margin-left:auto;font-size:0.75rem;color:var(--muted)"><%= new Date(m.created_at).toLocaleDateString('fr-BE') %></span>
            </div>
            <div style="font-weight:600;margin-bottom:4px"><%= m.subject || 'Sans objet' %></div>
            <div style="color:var(--muted);font-size:0.85rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= m.body.substring(0,80) %><%= m.body.length > 80 ? '...' : '' %></div>
          </div>
          <% }) %>
          <% } %>
        </div>

        <div>
          <h3 style="margin-bottom:16px">📤 Messages envoyés (<%= sent.length %>)</h3>
          <% if (sent.length === 0) { %>
          <div class="card" style="text-align:center;color:var(--muted);padding:40px">
            <div style="font-size:2.5rem">📮</div>
            <p>Aucun message envoyé</p>
          </div>
          <% } else { %>
          <% sent.forEach(m => { %>
          <div class="message-item" onclick="showMsg(this)" data-body="<%= m.body.replace(/"/g,'&quot;') %>" data-subject="<%= m.subject %>" data-from="Moi → <%= m.recipient_name %>">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px">
              <span style="font-size:1.2rem">📤</span>
              <strong><%= m.recipient_name %></strong>
              <span style="margin-left:auto;font-size:0.75rem;color:var(--muted)"><%= new Date(m.created_at).toLocaleDateString('fr-BE') %></span>
            </div>
            <div style="font-weight:600;margin-bottom:4px"><%= m.subject || 'Sans objet' %></div>
            <div style="color:var(--muted);font-size:0.85rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= m.body.substring(0,80) %><%= m.body.length > 80 ? '...' : '' %></div>
          </div>
          <% }) %>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Message Modal -->
<div id="msgModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:999;display:none;align-items:center;justify-content:center;padding:20px">
  <div style="background:white;border-radius:20px;padding:32px;max-width:500px;width:100%;box-shadow:var(--shadow-lg)">
    <h3 id="modalSubject" style="margin-bottom:8px"></h3>
    <p id="modalFrom" style="color:var(--muted);font-size:0.85rem;margin-bottom:20px"></p>
    <div id="modalBody" style="background:var(--bg);padding:16px;border-radius:10px;line-height:1.7"></div>
    <button onclick="closeModal()" class="btn btn-navy" style="margin-top:20px;width:100%">Fermer</button>
  </div>
</div>

<%- include('../partials/scripts') %>
<script>
function toggleCompose() {
  const box = document.getElementById('composeBox');
  box.style.display = box.style.display === 'none' ? 'block' : 'none';
}
async function sendMessage() {
  const recipient_id = document.getElementById('recipient').value;
  const subject = document.getElementById('subject').value;
  const body = document.getElementById('msgBody').value;
  if (!recipient_id || !body) { alert('Veuillez choisir un destinataire et écrire un message.'); return; }
  const resp = await fetch('/student/messages/send', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({recipient_id, subject, body}) });
  if (resp.ok) { alert('Message envoyé !'); location.reload(); }
}
function showMsg(el) {
  document.getElementById('modalSubject').textContent = el.dataset.subject || 'Sans objet';
  document.getElementById('modalFrom').textContent = 'De : ' + el.dataset.from;
  document.getElementById('modalBody').textContent = el.dataset.body;
  document.getElementById('msgModal').style.display = 'flex';
}
function closeModal() { document.getElementById('msgModal').style.display = 'none'; }
</script>
</body>
</html>
