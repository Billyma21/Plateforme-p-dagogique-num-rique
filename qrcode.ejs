// Progress page
router.get('/progress', requireStudent, async (req, res) => {
  const sid = req.session.userId;
  try {
    const user = await pool.query(`SELECT u.*, l.name as level_name, l.badge_icon, l.color as level_color, l.max_points FROM users u JOIN levels l ON u.level_id = l.id WHERE u.id = $1`, [sid]);
    const progress = await pool.query(`SELECT cp.*, c.name, c.total_points, m.name as module_name, m.color as module_color, m.icon FROM course_progress cp JOIN courses c ON cp.course_id = c.id JOIN modules m ON c.module_id = m.id WHERE cp.student_id = $1 ORDER BY m.order_index, c.order_index`, [sid]);
    const badges = await pool.query(`SELECT b.*, sb.earned_at FROM student_badges sb JOIN badges b ON sb.badge_id = b.id WHERE sb.student_id = $1`, [sid]);
    const history = await pool.query(`SELECT er.*, e.title, e.points, c.name as course_name FROM exercise_results er JOIN exercises e ON er.exercise_id = e.id JOIN courses c ON e.course_id = c.id WHERE er.student_id = $1 ORDER BY er.completed_at DESC LIMIT 20`, [sid]);
    const nextLevel = await pool.query(`SELECT * FROM levels WHERE min_points > $1 ORDER BY min_points LIMIT 1`, [user.rows[0].total_points]);
    res.render('student/progress', { user: user.rows[0], progress: progress.rows, badges: badges.rows, history: history.rows, nextLevel: nextLevel.rows[0] || null });
  } catch (err) {
    console.error(err);
    res.redirect('/student');
  }
});

// Messages
router.get('/messages', requireStudent, async (req, res) => {
  const sid = req.session.userId;
  try {
    const trainers = await pool.query(`SELECT id, first_name, username, avatar_color FROM users WHERE role IN ('trainer','admin') AND is_active = true ORDER BY first_name`);
    const inbox = await pool.query(`SELECT m.*, u.first_name as sender_name, u.avatar_color FROM messages m JOIN users u ON m.sender_id = u.id WHERE m.recipient_id = $1 ORDER BY m.created_at DESC`, [sid]);
    const sent = await pool.query(`SELECT m.*, u.first_name as recipient_name FROM messages m JOIN users u ON m.recipient_id = u.id WHERE m.sender_id = $1 ORDER BY m.created_at DESC`, [sid]);
    await pool.query(`UPDATE messages SET is_read = true WHERE recipient_id = $1`, [sid]);
    res.render('student/messages', { trainers: trainers.rows, inbox: inbox.rows, sent: sent.rows, user: { firstName: req.session.firstName } });
  } catch (err) {
    res.redirect('/student');
  }
});

router.post('/messages/send', requireStudent, async (req, res) => {
