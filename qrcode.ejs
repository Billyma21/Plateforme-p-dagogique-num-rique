      await pool.query(`UPDATE users SET password_hash = $1, first_name = $2, last_name = $3, updated_at = NOW() WHERE id = $4`, [hash, first_name, last_name, sid]);
    } else {
      await pool.query(`UPDATE users SET first_name = $1, last_name = $2, updated_at = NOW() WHERE id = $3`, [first_name, last_name, sid]);
