<%- include('../partials/head', {title: 'Cours & Exercices'}) %>
<body>
<div class="app-wrapper">
  <%- include('../partials/sidebar-student', {activePage: 'courses', user, unreadMessages: 0}) %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title">
        <h1>📚 Cours & Exercices</h1>
        <p>Choisissez un cours pour commencer</p>
      </div>
    </div>
    <div class="page-content">
      <% modules.forEach(mod => { %>
      <% const modCourses = courses.filter(c => c.module_name === mod.name); %>
      <% if (modCourses.length > 0) { %>
      <div style="margin-bottom:40px">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px">
          <div style="width:48px;height:48px;border-radius:14px;background:<%= mod.color || '#3B82F6' %>;display:flex;align-items:center;justify-content:center;font-size:1.5rem"><%= mod.icon %></div>
          <div>
            <h2 style="margin:0">Module <%= mod.name %></h2>
            <p style="color:var(--muted);font-size:0.9rem"><%= mod.description || '' %></p>
          </div>
        </div>
        <div class="grid-2">
          <% modCourses.forEach(course => { %>
          <% const pct = course.total_exercises > 0 ? Math.round((course.exercises_completed || 0) / course.exercise_count * 100) : 0; %>
          <div class="card" style="border-top:4px solid <%= mod.color || '#3B82F6' %>">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px">
              <div>
                <h3 style="margin-bottom:4px"><%= course.name %></h3>
                <p style="color:var(--muted);font-size:0.85rem"><%= course.description || '' %></p>
              </div>
              <% if (course.is_completed) { %>
              <span style="font-size:1.5rem">✅</span>
              <% } %>
            </div>
            <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap">
              <span class="badge-pill badge-info"><%= course.module_icon %> <%= course.module_name %></span>
              <span class="badge-pill <%= course.difficulty === 'débutant' ? 'badge-success' : course.difficulty === 'intermédiaire' ? 'badge-warning' : 'badge-danger' %>">
                <%= course.difficulty %>
              </span>
              <span class="badge-pill badge-purple">🏆 <%= course.total_points %> pts</span>
            </div>
            <% if (course.exercises_completed > 0) { %>
            <div style="margin-bottom:12px">
              <div style="display:flex;justify-content:space-between;font-size:0.85rem;margin-bottom:4px">
                <span style="font-weight:700;color:var(--muted)">Progression</span>
                <span style="font-weight:800;color:var(--navy)"><%= course.exercises_completed %>/<%= course.exercise_count %> exercices</span>
              </div>
              <div class="progress-bar"><div class="progress-fill" style="width:<%= pct %>%;background:<%= mod.color || '#3B82F6' %>"></div></div>
            </div>
            <% } %>
            <div style="display:flex;gap:8px;flex-wrap:wrap">
              <a href="/student/courses/<%= course.id %>/exercises" class="btn btn-navy btn-sm">
                📝 Faire les exercices
              </a>
              <a href="/student/courses/<%= course.id %>/qrcode" class="btn btn-outline btn-sm">
                📱 QR Code
              </a>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>
      <% }) %>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
</body>
</html>
